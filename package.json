{
  "name": "dracaenium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "NEXT_OUTPUT=export next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm test && npm run build && npm run build:pages && npm run audit",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
